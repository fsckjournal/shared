#!/usr/bin/env python3
"""Append one schema-validated event to the shared handoff spine.

Atomic (single line, O_APPEND), schema-checked, and it auto-fills ts/git/env
so callers can't forget them. Zero third-party deps.

Usage:
    handoff-append --from hag --to slut --kind handoff \
        --summary "Loudness handoff table regenerated; slut can join on content_sha256." \
        [--open "which BPM wins on disagreement?"] \
        [--needs "local $TAGSLUT_DB"] \
        [--artifact tools/mixslice/out.parquet:hag] \
        [--session 12f336bd] [--env local]

Reads nothing from stdin. Prints the written JSON line to stdout.
Exit codes: 0 ok, 2 validation/usage error.
"""
from __future__ import annotations
import argparse, datetime, json, os, subprocess, sys, re

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
LOG = os.path.join(ROOT, "handoffs", "handoff.jsonl")
SCHEMA = os.path.join(ROOT, "schema", "handoff.schema.json")
SCHEMA_VERSION = 1
REPOS = {"hag", "slut"}


def _git(cwd, *args):
    try:
        return subprocess.check_output(["git", "-C", cwd, *args],
                                       stderr=subprocess.DEVNULL, text=True).strip()
    except Exception:
        return None


def _detect_git():
    # Best-effort: the sibling source repo the caller is in, else None.
    cwd = os.environ.get("HANDOFF_SRC") or os.getcwd()
    sha = _git(cwd, "rev-parse", "--short", "HEAD")
    branch = _git(cwd, "rev-parse", "--abbrev-ref", "HEAD")
    g = {}
    if sha: g["sha"] = sha
    if branch: g["branch"] = branch
    return g or None


def _detect_env():
    if os.environ.get("HANDOFF_ENV"):
        return os.environ["HANDOFF_ENV"]
    # heuristic: whether the heavy mounts are visible
    if os.environ.get("TAGSLUT_DB") and os.path.exists(os.environ["TAGSLUT_DB"]):
        return "local"
    return "unknown"


def _resources():
    r = {}
    db = os.environ.get("TAGSLUT_DB")
    lib = os.environ.get("MASTER_LIBRARY")
    if db is not None: r["tagslut_db"] = bool(db and os.path.exists(db))
    if lib is not None: r["master_library"] = bool(lib and os.path.exists(lib))
    return r or None


def _validate(evt):
    """Minimal self-contained validation against the required rules.

    We avoid a jsonschema dependency; this enforces the invariants that matter.
    """
    errs = []
    if evt["from"] not in REPOS: errs.append(f"from must be one of {REPOS}")
    if evt["to"] not in REPOS | {"both"}: errs.append("to must be hag|slut|both")
    if evt["kind"] not in {"handoff","blocked","question","answer","data-release","note"}:
        errs.append("bad kind")
    if not evt.get("summary"): errs.append("summary required")
    if len(evt.get("summary","")) > 2000: errs.append("summary too long (>2000)")
    if evt["kind"] == "blocked" and not evt.get("needs"):
        errs.append("kind=blocked requires at least one --needs")
    for a in evt.get("artifacts", []):
        sha = a.get("sha256")
        if sha and not re.fullmatch(r"[0-9a-f]{64}", sha):
            errs.append(f"bad sha256 for {a['path']}")
    return errs


def main():
    p = argparse.ArgumentParser(description="Append a handoff event.")
    p.add_argument("--from", dest="frm", required=True, choices=sorted(REPOS))
    p.add_argument("--to", required=True, choices=sorted(REPOS | {"both"}))
    p.add_argument("--kind", required=True,
                   choices=["handoff","blocked","question","answer","data-release","note"])
    p.add_argument("--summary", required=True)
    p.add_argument("--open", dest="open_q", action="append", default=[])
    p.add_argument("--needs", action="append", default=[])
    p.add_argument("--artifact", action="append", default=[],
                   help="path[:repo[:sha256[:generation]]]")
    p.add_argument("--session", default=None)
    p.add_argument("--env", default=None, choices=["local","web","phone","unknown"])
    args = p.parse_args()

    artifacts = []
    for spec in args.artifact:
        parts = spec.split(":")
        a = {"path": parts[0]}
        if len(parts) > 1 and parts[1]: a["repo"] = parts[1]
        if len(parts) > 2 and parts[2]: a["sha256"] = parts[2]
        if len(parts) > 3 and parts[3]: a["generation"] = int(parts[3])
        artifacts.append(a)

    evt = {
        "schema_version": SCHEMA_VERSION,
        "ts": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "from": args.frm,
        "to": args.to,
        "kind": args.kind,
        "summary": args.summary,
    }
    g = _detect_git()
    if g: evt["git"] = g
    evt["env"] = args.env or _detect_env()
    res = _resources()
    if res: evt["resources"] = res
    if args.open_q: evt["open_questions"] = args.open_q
    if args.needs: evt["needs"] = args.needs
    if artifacts: evt["artifacts"] = artifacts
    if args.session: evt["session"] = args.session

    errs = _validate(evt)
    if errs:
        print("handoff-append: refused, invalid event:", file=sys.stderr)
        for e in errs: print("  - " + e, file=sys.stderr)
        sys.exit(2)

    line = json.dumps(evt, ensure_ascii=False, sort_keys=True)
    os.makedirs(os.path.dirname(LOG), exist_ok=True)
    # O_APPEND makes the single write atomic across concurrent producers.
    fd = os.open(LOG, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)
    try:
        os.write(fd, (line + "\n").encode("utf-8"))
    finally:
        os.close(fd)
    print(line)


if __name__ == "__main__":
    main()
