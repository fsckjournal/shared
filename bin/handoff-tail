#!/usr/bin/env python3
"""Read the shared handoff spine — the first thing an agent does on resume.

Shows the most recent events, optionally filtered to what THIS repo needs to
act on. Also surfaces still-open questions and unresolved blocks so nothing
silently rots.

Usage:
    handoff-tail                      # last 10 events, all repos
    handoff-tail --to hag             # events addressed to hag (or 'both')
    handoff-tail --to slut --open     # + list unresolved questions/blocks
    handoff-tail -n 25 --json         # raw JSONL passthrough for scripting
"""
from __future__ import annotations
import argparse, json, os, sys

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
LOG = os.path.join(ROOT, "handoffs", "handoff.jsonl")


def load():
    if not os.path.exists(LOG):
        return []
    out = []
    for ln in open(LOG, encoding="utf-8"):
        ln = ln.strip()
        if not ln:
            continue
        try:
            out.append(json.loads(ln))
        except json.JSONDecodeError:
            print(f"handoff-tail: WARNING skipping malformed line", file=sys.stderr)
    return out


def main():
    p = argparse.ArgumentParser(description="Tail the handoff spine.")
    p.add_argument("-n", type=int, default=10)
    p.add_argument("--to", choices=["hag", "slut"], help="only events addressed to this repo (or 'both')")
    p.add_argument("--open", action="store_true", help="also list unresolved questions/blocks")
    p.add_argument("--json", action="store_true", help="print raw JSONL")
    args = p.parse_args()

    evts = load()
    if args.to:
        evts = [e for e in evts if e.get("to") in (args.to, "both")]

    tail = evts[-args.n:]
    if args.json:
        for e in tail:
            print(json.dumps(e, ensure_ascii=False, sort_keys=True))
        return

    if not tail:
        print("(no handoff events yet)")
    for e in tail:
        g = e.get("git", {})
        pos = f" @{g.get('sha','?')}/{g.get('branch','?')}" if g else ""
        env = e.get("env", "?")
        re_s = f" re#{e['re']}" if e.get("re") else ""
        st = e.get("status", "?")
        print(f"#{e.get('id','?')} [{e.get('ts','?')}] {e.get('from','?')}→{e.get('to','?')} "
              f"{e.get('kind','?').upper()}/{st}{re_s}{pos} ({env})")
        print(f"    {e.get('summary','').strip()}")
        for a in e.get("artifacts", []):
            gen = f" gen{a['generation']}" if 'generation' in a else ""
            print(f"    · artifact: {a.get('repo','?')}:{a['path']}{gen}")

    if args.open:
        # An event with status=open is cleared when a later event replies to it
        # (re==id) with status=answered. Scan the FULL log, not just the filtered tail.
        full = load()
        answered = {e["re"] for e in full if e.get("status") == "answered" and e.get("re")}
        print("\n--- still open (needs a reply/action) ---")
        any_open = False
        for e in full:
            if e.get("status") == "open" and e.get("id") not in answered:
                # respect --to filter if given
                if args.to and e.get("to") not in (args.to, "both"):
                    continue
                any_open = True
                print(f"  #{e['id']} [{e.get('from')}→{e.get('to')}] {e.get('summary','').strip()[:120]}")
                for q in e.get("open_questions", []):
                    print(f"        ? {q}")
                for nd in e.get("needs", []):
                    print(f"        ⛔ needs: {nd}")
        if not any_open:
            print("  (nothing open)")


if __name__ == "__main__":
    main()
